{
  "name": "opensentry",
  "author": {
    "email": "skss.vfx@gmail.com",
    "name": "Sharma SK",
    "url": "https://github.com/sharma-open-source"
  },
  "publishConfig": {
    "access": "public"
  },
  "version": "1.2.1",
  "description": "Tiered prompt-injection validation layer. Zero-dep sub-ms Tier 0 core (Node + edge identical), optional local ML + remote guard tiers.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharma-open-source/opensentry.git"
  },
  "homepage": "https://github.com/sharma-open-source/opensentry",
  "bugs": {
    "url": "https://github.com/sharma-open-source/opensentry/issues"
  },
  "funding": "https://github.com/sponsors/sharma-open-source",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./confusables": {
      "types": "./dist/confusables/index.d.ts",
      "import": "./dist/confusables/index.js",
      "require": "./dist/confusables/index.cjs"
    },
    "./spotlight": {
      "types": "./dist/spotlight/index.d.ts",
      "import": "./dist/spotlight/index.js",
      "require": "./dist/spotlight/index.cjs"
    },
    "./egress": {
      "types": "./dist/egress/index.d.ts",
      "import": "./dist/egress/index.js",
      "require": "./dist/egress/index.cjs"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.ts",
      "import": "./dist/prompt/index.js",
      "require": "./dist/prompt/index.cjs"
    },
    "./canary": {
      "types": "./dist/canary/index.d.ts",
      "import": "./dist/canary/index.js",
      "require": "./dist/canary/index.cjs"
    },
    "./taint": {
      "types": "./dist/taint/index.d.ts",
      "import": "./dist/taint/index.js",
      "require": "./dist/taint/index.cjs"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.js",
      "require": "./dist/session/index.cjs"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "import": "./dist/express/index.js",
      "require": "./dist/express/index.cjs"
    },
    "./hono": {
      "types": "./dist/hono/index.d.ts",
      "import": "./dist/hono/index.js",
      "require": "./dist/hono/index.cjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "require": "./dist/next/index.cjs"
    },
    "./onnx": {
      "types": "./dist/onnx/index.d.ts",
      "import": "./dist/onnx/index.js",
      "require": "./dist/onnx/index.cjs"
    },
    "./wasm": {
      "types": "./dist/wasm/index.d.ts",
      "import": "./dist/wasm/index.js",
      "require": "./dist/wasm/index.cjs"
    },
    "./remote": {
      "types": "./dist/remote/index.d.ts",
      "import": "./dist/remote/index.js",
      "require": "./dist/remote/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run -c vitest.perf.config.ts",
    "eval": "vitest run -c vitest.eval.config.ts",
    "bench:fetch": "node bench/fetch.mjs",
    "bench": "vitest run -c vitest.bench.config.ts",
    "bench:snapshot": "node bench/snapshot.mjs",
    "ci": "biome check src && tsc --noEmit && vitest run && vitest run -c vitest.perf.config.ts && vitest run -c vitest.eval.config.ts"
  },
  "keywords": [
    "prompt-injection",
    "prompt-injection-detection",
    "prompt-security",
    "llm-security",
    "llm-guard",
    "llm-firewall",
    "guardrail",
    "ai-safety",
    "genai-security",
    "ai-security",
    "agent-security",
    "prompt-defense",
    "prompt-sanitization",
    "input-validation",
    "owasp",
    "owasp-llm",
    "owasp-llm01",
    "indirect-prompt-injection",
    "jailbreak-detection",
    "jailbreak-prevention",
    "prompt-filter",
    "content-filter",
    "security",
    "cybersecurity",
    "unicode-normalization",
    "confusables",
    "homoglyph",
    "middleware",
    "express",
    "nextjs",
    "hono",
    "edge",
    "typescript",
    "nodejs",
    "openai",
    "anthropic",
    "gemini",
    "llm",
    "rag",
    "ai-agent"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@huggingface/transformers": "^4.2.0",
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.0.0",
    "onnxruntime-node": "^1.20.0",
    "onnxruntime-web": "^1.20.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "onnxruntime-node": {
      "optional": true
    },
    "onnxruntime-web": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}