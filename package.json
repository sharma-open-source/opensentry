{
  "name": "opensentry",
  "version": "0.1.0",
  "description": "Tiered prompt-injection validation layer. Zero-dep sub-ms Tier 0 core (Node + edge identical), optional local ML + remote guard tiers.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./confusables": {
      "types": "./dist/confusables/index.d.ts",
      "import": "./dist/confusables/index.js"
    },
    "./spotlight": {
      "types": "./dist/spotlight/index.d.ts",
      "import": "./dist/spotlight/index.js"
    },
    "./egress": {
      "types": "./dist/egress/index.d.ts",
      "import": "./dist/egress/index.js"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.ts",
      "import": "./dist/prompt/index.js"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "import": "./dist/express/index.js"
    },
    "./hono": {
      "types": "./dist/hono/index.d.ts",
      "import": "./dist/hono/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    },
    "./onnx": {
      "types": "./dist/onnx/index.d.ts",
      "import": "./dist/onnx/index.js"
    },
    "./wasm": {
      "types": "./dist/wasm/index.d.ts",
      "import": "./dist/wasm/index.js"
    },
    "./remote": {
      "types": "./dist/remote/index.d.ts",
      "import": "./dist/remote/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run -c vitest.perf.config.ts",
    "eval": "vitest run -c vitest.eval.config.ts",
    "bench:fetch": "node bench/fetch.mjs",
    "bench": "vitest run -c vitest.bench.config.ts",
    "bench:snapshot": "node bench/snapshot.mjs",
    "ci": "biome check src && tsc --noEmit && vitest run && vitest run -c vitest.perf.config.ts && vitest run -c vitest.eval.config.ts"
  },
  "keywords": [
    "prompt-injection",
    "llm-security",
    "guardrail",
    "ai-safety",
    "owasp-llm01",
    "unicode-normalization",
    "edge"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@huggingface/transformers": "^4.2.0",
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^3.0.0",
    "onnxruntime-node": "^1.20.0",
    "onnxruntime-web": "^1.20.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "onnxruntime-node": {
      "optional": true
    },
    "onnxruntime-web": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
